---
import Layout from "../layouts/Layout.astro";
import { MACOS_DOWNLOAD_NAME, MACOS_DOWNLOAD_PATH } from "../lib/downloads";
---

<Layout title="Download Molde">
  <section class="download-page">
    <p class="eyebrow">Download</p>
    <h1>Molde for macOS</h1>
    <p class="subcopy">
      Apple Silicon build for local PostgreSQL-aware form building.
    </p>
    <a class="download-link" href={MACOS_DOWNLOAD_PATH} download={MACOS_DOWNLOAD_NAME}>
      Download {MACOS_DOWNLOAD_NAME}
    </a>
  </section>
</Layout>

<style>
  .download-page {
    display: flex;
    min-height: calc(100vh - 78px);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.25rem;
    text-align: center;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin-top: 0.85rem;
    font-size: clamp(2.5rem, 7vw, 5.2rem);
    font-weight: 580;
    line-height: 0.96;
  }

  .subcopy {
    margin-top: 1rem;
    color: var(--muted);
    font-size: 1rem;
  }

  .download-link {
    margin-top: 2rem;
    border-radius: 999px;
    background: #f7f3eb;
    padding: 0.82rem 1.65rem;
    color: #080b11;
    font-weight: 700;
  }
</style>
