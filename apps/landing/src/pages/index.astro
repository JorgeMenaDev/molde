---
import Layout from "../layouts/Layout.astro";
import { MACOS_DOWNLOAD_NAME, MACOS_DOWNLOAD_PATH } from "../lib/downloads";
---

<Layout>
  <section class="hero">
    <div class="hero-copy">
      <p class="brand">Molde</p>
      <h1>Shape PostgreSQL-aware forms on your desktop.</h1>
      <p class="subcopy">
        Build dense form workflows, map fields to schema columns, preview the
        user experience, and persist projects locally.
      </p>
      <a
        id="download-macos"
        class="download"
        href={MACOS_DOWNLOAD_PATH}
        download={MACOS_DOWNLOAD_NAME}
        data-download-path={MACOS_DOWNLOAD_PATH}
      >
        <svg viewBox="0 0 814 1000" aria-hidden="true">
          <path
            fill="currentColor"
            d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
          />
        </svg>
        Download for macOS
      </a>
    </div>

    <figure class="product-shot">
      <img src="/molde-desktop.png" alt="Molde desktop app showing field configuration, PostgreSQL mapping, and live form preview." />
    </figure>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    min-height: calc(100vh - 78px);
    flex-direction: column;
    align-items: center;
    padding: 1.1rem 1.4rem 0;
    text-align: center;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    display: flex;
    max-width: 920px;
    flex-direction: column;
    align-items: center;
    animation: rise 700ms ease both;
  }

  .brand {
    margin-bottom: 0.8rem;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 920px;
    font-size: clamp(3rem, 7vw, 6.15rem);
    font-weight: 580;
    line-height: 0.94;
  }

  .subcopy {
    margin-top: 1.25rem;
    max-width: 650px;
    color: var(--muted);
    font-size: clamp(1rem, 1.6vw, 1.18rem);
    line-height: 1.55;
  }

  .download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 44px;
    margin-top: 2.1rem;
    border-radius: 999px;
    background: #f7f3eb;
    padding: 0.78rem 1.72rem;
    color: #080b11;
    font-size: 0.94rem;
    font-weight: 700;
    box-shadow: 0 24px 70px rgba(247, 243, 235, 0.12);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .download:hover {
    transform: translateY(-2px);
    background: white;
    box-shadow: 0 30px 90px rgba(142, 227, 205, 0.18);
  }

  .download:active {
    transform: translateY(0);
  }

  .download svg {
    width: 1rem;
    height: 1rem;
  }

  .product-shot {
    position: relative;
    width: min(92vw, 1400px);
    margin-top: 5.8vh;
    animation: product-in 900ms 120ms ease both;
  }

  .product-shot::before {
    content: "";
    position: absolute;
    inset: 7% 8% auto;
    height: 34%;
    border-radius: 999px;
    background: rgba(142, 227, 205, 0.18);
    filter: blur(80px);
    transform: translateY(-20%);
  }

  .product-shot img {
    position: relative;
    width: 100%;
    border-radius: 18px;
    border: 1px solid var(--line);
    box-shadow:
      0 26px 90px rgba(0, 0, 0, 0.54),
      0 1px 0 rgba(255, 255, 255, 0.08) inset;
    mask-image: linear-gradient(to bottom, black 0%, black 78%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 78%, transparent 100%);
  }

  @keyframes product-in {
    from {
      opacity: 0;
      transform: translateY(22px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 720px) {
    .hero {
      min-height: calc(100svh - 60px);
      padding: 1.2rem 1rem 0;
    }

    h1 {
      font-size: clamp(2.55rem, 13vw, 4.4rem);
    }

    .subcopy {
      max-width: 28rem;
    }

    .product-shot {
      width: 160vw;
      margin-top: 4rem;
    }
  }
</style>
